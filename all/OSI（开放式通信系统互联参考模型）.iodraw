          <mxGeometry x="230" y="270" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fruVxbZvgm2jl-kmFIZ6-3" value="会话层" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="230" y="390" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fruVxbZvgm2jl-kmFIZ6-4" value="传输层" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="230" y="550" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fruVxbZvgm2jl-kmFIZ6-5" value="网络层" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="230" y="710" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fruVxbZvgm2jl-kmFIZ6-6" value="数据链路层" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="220" y="860" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="fruVxbZvgm2jl-kmFIZ6-7" value="物理层" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
          <mxGeometry x="230" y="1090" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-1" value="&lt;span style=&quot;color: rgba(0, 0, 0, 0.8); font-family: Arial, Helvetica, sans-serif; font-size: 14px; text-align: start; background-color: rgb(239, 234, 231);&quot;&gt;负责数据的物理传输，定义硬件特性（如电缆、光纤、电压等）。主要传输比特流，典型设备包括&lt;/span&gt;&lt;span style=&quot;font-family: Arial, Helvetica, sans-serif; font-size: 14px; text-align: start; background-color: rgb(255, 51, 51);&quot;&gt;&lt;font color=&quot;#ffffff&quot;&gt;集线器和网线接口&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0.8); font-family: Arial, Helvetica, sans-serif; font-size: 14px; text-align: start; background-color: rgb(239, 234, 231);&quot;&gt;（如RJ45）。&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="380" y="1105" width="390" height="65" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-2" value="&lt;span style=&quot;text-align: start; background-color: rgb(239, 234, 231);&quot;&gt;&lt;font color=&quot;#33001a&quot; face=&quot;Arial, Helvetica, sans-serif&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;接收物理层的数据，提供可靠的数据传输，负责帧的封装并将其传输到网络层、将网络层的数据帧，拆装为位流形式的数据转发到物理层物理地址实现数据交互，&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(25, 27, 31); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Helvetica Neue&amp;quot;, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;MiSans L3&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;负责建立和管理节点间的链路，通过各种控制协议，&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;text-align: start;&quot;&gt;&lt;font style=&quot;&quot; face=&quot;Arial, Helvetica, sans-serif&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;&lt;span style=&quot;color: rgb(51, 0, 26); background-color: rgb(239, 234, 231);&quot;&gt;（MAC地址）寻址，将有差错的物理信道变为无差错的、错误检测与纠正。典型设备为&lt;/span&gt;&lt;font color=&quot;#ffffff&quot;&gt;&lt;span style=&quot;background-color: rgb(204, 0, 0);&quot;&gt;交换机&lt;/span&gt;&lt;span style=&quot;background-color: rgb(239, 234, 231);&quot;&gt;。&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="368" y="850" width="370" height="135" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-3" value="通过路由选择算法，为报文或通信子网选择最适当的路径。控制数据链路层与传输层之间的信息转发，建立、维持和终止网络的连接，&lt;span style=&quot;color: rgb(25, 27, 31); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Helvetica Neue&amp;quot;, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;MiSans L3&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;数据链路层的数据在这一层被转换为数据包，然后通过路径选择、分段组合、顺序、进/出路由等控制，将信息从一个网络设备传送到另一个网络设备&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;color: rgb(25, 27, 31); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Helvetica Neue&amp;quot;, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;MiSans L3&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start; background-color: rgb(255, 255, 255);&quot;&gt;。&lt;/span&gt;，使用IP地址标识设备。核心协议包括IP、ICMP等，典型设备为&lt;font color=&quot;#ffffff&quot; style=&quot;background-color: rgb(255, 0, 0);&quot;&gt;路由器&lt;/font&gt;。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="405" y="690" width="316" height="110" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-4" value="&lt;span style=&quot;text-align: start; background-color: rgb(239, 234, 231);&quot;&gt;&lt;font face=&quot;Arial, Helvetica, sans-serif&quot;&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;建立主机端到端的链接，为会话层和网络层提供端到端可靠的和透明的数据传输服务，确保数据能完整的传输到网络层。主要协议为TCP和UDP，数据单位为段（Segment）。&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="382" y="542.5" width="420" height="75" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-5" value="管理通信会话的建立、维护和终止，支持同步和恢复功能。该层的通信由不同设备中的应用程序之间的服务请求和响应组成。常用于身份验证和会话管理。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="414" y="405" width="356" height="30" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-6" value="负责数据的格式化/数据编码、加密解密和压缩解压，格式转换&lt;span style=&quot;color: rgb(25, 27, 31); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Helvetica Neue&amp;quot;, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;MiSans L3&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; text-align: start; white-space: pre; background-color: rgb(244, 246, 249);&quot;&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;确保一个系统的应用层发送的数据能被另一个系统的应用层识别&lt;/font&gt;&lt;/span&gt;确保不同系统间的数据交换。如果必要，该层可提供一种标准表示形式，用于将计算机内部的多种数据格式转换成通信中采用的标准表示形式。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="405" y="285" width="340" height="30" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-7" value="直接面向用户，提供网络服务接口。为应用程序或用户请求提供各种请求服务，&lt;span style=&quot;background-color: initial;&quot;&gt;常见协议包括HTTP、FTP、SMTP等。&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;container=1;" parent="1" vertex="1">
          <mxGeometry x="395" y="145" width="360" height="55" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-8" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" parent="1" vertex="1">
          <mxGeometry x="860" y="115" width="704.86" height="395" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-10" value="&lt;span style=&quot;color: rgb(25, 27, 31); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Helvetica Neue&amp;quot;, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;MiSans L3&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start; white-space: pre; background-color: rgb(244, 246, 249);&quot;&gt;管理通信设备和网络媒体之间的互联互通。&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="510" y="1090" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-11" value="&lt;span style=&quot;color: rgb(25, 27, 31); font-family: -apple-system, BlinkMacSystemFont, &amp;quot;Helvetica Neue&amp;quot;, &amp;quot;PingFang SC&amp;quot;, &amp;quot;Microsoft YaHei&amp;quot;, &amp;quot;Source Han Sans SC&amp;quot;, &amp;quot;Noto Sans CJK SC&amp;quot;, &amp;quot;WenQuanYi Micro Hei&amp;quot;, &amp;quot;MiSans L3&amp;quot;, &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: medium; text-align: start; white-space: pre; background-color: rgb(244, 246, 249);&quot;&gt;提供介质访问和链路管理&lt;/span&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="430" y="850" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-12" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;IP选址及路由选择。&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="382" y="660" width="195" height="30" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-13" value="数据通信" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="380" y="520" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="XRSpViTIvMp-7Ewlj45h-14" value="创建、管理和维护会话。" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="382" y="375" width="236" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
